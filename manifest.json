{
  "manifest_version": 3,
  "name": "NetPin",
  "description": "Analyze hosting, privacy, carbon footprint, and route path for the current website.",
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "cookies",
    "declarativeNetRequest",
    "notifications"
  ],
  "host_permissions": [
    "http://ip-api.com/*",
    "https://greencheck.thegreenwebfoundation.org/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}